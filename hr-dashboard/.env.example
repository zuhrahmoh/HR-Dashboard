# Local Postgres (Phase 13)
DATABASE_URL="postgresql://hr_dashboard:hr_dashboard@localhost:5432/hr_dashboard"

# Odoo (required for Odoo pages)
ODOO_URL="https://laser.rampslogistics.com"
ODOO_USERNAME="itrd@rampslogistics.com"
ODOO_PASSWORD=""
ODOO_DB="prod_db_jan_6_2023_v15"
ODOO_INSECURE_TLS="0"
ODOO_CACHE_TTL_MS="30000"

# Odoo contract change lines (employee profile → Contract notification tab). Required for /contracts contract changes table.
ODOO_CONTRACT_CHANGE_LINE_MODEL=""
# Optional overrides if auto-detection fails (technical field names on the line model):
ODOO_CONTRACT_CHANGE_EMPLOYEE_FIELD="employee_id"
ODOO_CONTRACT_CHANGE_TYPE_FIELD=""
ODOO_CONTRACT_CHANGE_STATUS_FIELD=""
ODOO_CONTRACT_CHANGE_DESCRIPTION_FIELD=""

# Odoo medical enrolments & EAP (read-only tables on /medical-enrollments-eap). Defaults match Laser.
ODOO_MEDICAL_ENROLMENT_LINE_MODEL="hr.medical.enrolment"
ODOO_EAP_LINE_MODEL="hr.eap"

# Odoo progressive discipline (employee profile → HR Settings). Defaults match Laser.
ODOO_DISCIPLINE_CASE_LINE_MODEL="hr.discipline.case"
# "Include in Report" is stored in Postgres (DisciplinaryCaseInclude), not in Odoo.

# Entra ID — hr-login (browser sign-in; separate from GRAPH_* app-only credentials)
AUTH_TENANT_ID=""
AUTH_CLIENT_ID=""
AUTH_CLIENT_SECRET=""
AUTH_REDIRECT_URI="http://localhost:3000/auth/callback"
AUTH_REQUIRED_ROLE="HR.User"
# Random string, 32+ characters (openssl rand -base64 32). Signs the session cookie; not from Microsoft.
NUXT_SESSION_PASSWORD=""

# Microsoft Graph / SharePoint (required if using SharePoint expenses & compensation)
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
SP_HOSTNAME=""
SP_SITE_ID=""
SP_SITE_PATH="/"
SP_LIST_ID=""
SP_CACHE_TTL_MS="600000"
NUXT_SHAREPOINT_SITE_ID=""
NUXT_SHAREPOINT_SALARY_LIST_ID=""
NUXT_SHAREPOINT_SALARY_CACHE_TTL_MS="600000"
